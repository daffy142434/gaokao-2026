<!DOCTYPE html>
<html lang="zh-CN" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=3.0, user-scalable=yes">
  <title>雪峰AI高考志愿填报助手</title>
  <meta name="description" content="张雪峰风格AI志愿填报分析，一分一段表+院校数据库+实时分数线">
  <meta name="version" content="v3.20260625-3review">
  <script>window.GAOKAO_VERSION='v3.20260625-3review'</script>
  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>tailwind.config={darkMode:'class'}</script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'PingFang SC','Microsoft YaHei',sans-serif}
    .dark body,.dark{background:#1a1a2e!important;color:#e5e7eb}
    ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:3px}
    .msg-content h1,.msg-content h2,.msg-content h3{font-weight:700;margin:.5em 0 .25em}
    .msg-content h1{font-size:1.2em}.msg-content h2{font-size:1.1em}.msg-content h3{font-size:1em}
    .msg-content p{margin:.3em 0;line-height:1.7}
    .msg-content ul,.msg-content ol{padding-left:1.5em;margin:.3em 0}
    .msg-content li{margin:.15em 0}
    .msg-content strong{color:var(--tw-prose-bold,#1a1a1a)}
    .msg-content code{background:#f3f4f6;padding:.15em .4em;border-radius:3px;font-size:.9em}
    .msg-content pre{background:#1e1e1e;color:#d4d4d4;padding:.8em;border-radius:6px;overflow-x:auto;margin:.5em 0;font-size:.85em}
    .msg-content blockquote{border-left:3px solid #e5e7eb;padding-left:1em;margin:.5em 0;color:#6b7280}
    .msg-content table{border-collapse:collapse;margin:.5em 0;font-size:.85em;width:100%}
    .msg-content th,.msg-content td{border:1px solid #e5e7eb;padding:.4em .6em;text-align:left}
    .msg-content th{background:#f9fafb;font-weight:600}
    @keyframes bounce{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
    .dot{width:8px;height:8px;background:#9ca3af;border-radius:50%;display:inline-block;animation:bounce 1.4s infinite ease-in-out both}
    .dot:nth-child(1){animation-delay:-.32s}.dot:nth-child(2){animation-delay:-.16s}
    @keyframes slideIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    .msg-enter{animation:slideIn .3s ease-out}
    @keyframes pulse-bg{0%,100%{background:#eff6ff}50%{background:#dbeafe}}
    .thinking-pulse{animation:pulse-bg 1.5s ease-in-out infinite}
    .school-link{cursor:pointer;color:#2563eb;text-decoration:underline;text-decoration-style:dotted}
    .school-link:hover{color:#1d4ed8}
    .dark .msg-content strong{color:#f3f4f6}
    .dark .msg-content code{background:#374151}
    .dark .msg-content blockquote{border-color:#4b5563;color:#9ca3af}
    .dark .msg-content th{background:#374151}
    .dark .msg-content td,.dark .msg-content th{border-color:#4b5563}
  </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
<div id="app">
  <!-- 顶部导航 + 快速设置 -->
  <header class="fixed top-0 left-0 right-0 z-30 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex items-center h-14 px-3 max-w-6xl mx-auto gap-2">
      <button @click="showSidebar=!showSidebar" class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <h1 class="text-base md:text-lg font-bold text-gray-800 dark:text-white whitespace-nowrap">🎓 雪峰AI</h1>
      <!-- 快速设置 -->
      <div class="flex items-center gap-1.5 flex-1 justify-center min-w-0">
        <select v-model="profile.province" @change="saveProfile();fetchRank()" class="text-xs border border-gray-300 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-700 dark:text-white min-w-0">
          <option value="">省份</option>
          <option v-for="p in allProvinces" :key="p" :value="p">{{p}}</option>
        </select>
        <input v-model="profile.score" @change="saveProfile();fetchRank()" type="number" placeholder="分数" class="text-xs border border-gray-300 dark:border-gray-600 rounded-lg px-2 py-1.5 w-16 bg-white dark:bg-gray-700 dark:text-white">
        <select v-model="profile.type" @change="saveProfile();fetchRank()" class="text-xs border border-gray-300 dark:border-gray-600 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-700 dark:text-white">
          <option value="">类别</option><option value="物理类">物理类</option><option value="历史类">历史类</option>
        </select>
        <span v-if="rankInfo" class="text-xs text-blue-600 dark:text-blue-400 whitespace-nowrap hidden sm:inline">位次:{{rankInfo.rank}}</span>
      </div>
      <div class="flex items-center gap-1">
        <button @click="darkMode=!darkMode;saveDark()" class="p-1.5 text-sm hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg" :title="darkMode?'浅色':'深色'">{{darkMode?'☀️':'🌙'}}</button>
        <button @click="showCutoffs=true" class="px-1.5 py-1 text-xs text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg">📊分数线</button>
        <button @click="showMajors=true" class="px-1.5 py-1 text-xs text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">📖专业</button>
        <div class="relative">
          <button @click.stop="showScoreLinks=!showScoreLinks" class="px-1.5 py-1 text-xs text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">🔗查分</button>
          <div v-if="showScoreLinks" class="absolute top-10 right-0 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl z-50 w-72 max-h-80 overflow-hidden" @click.stop>
            <div class="p-2 border-b dark:border-gray-700 bg-gray-50 dark:bg-gray-900"><div class="text-xs font-semibold">选省份直接跳转查分</div></div>
            <div class="p-2 grid grid-cols-4 gap-1"><button v-for="p in scoreProvinces" :key="p" @click="gotoScore(p)" class="text-xs px-1.5 py-1 rounded border border-gray-200 dark:border-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/30">{{p}}</button></div>
          </div>
        </div>
        <button @click="newChat" class="px-2 py-1 bg-blue-600 text-white text-xs rounded-lg hover:bg-blue-700">+新对话</button>
        <button v-if="messages.length>3" @click="exportForm" class="px-2 py-1 bg-green-600 text-white text-xs rounded-lg hover:bg-green-700">📋导出</button>
      </div>
    </div>
  </header>

  <!-- 新用户引导 -->
  <div v-if="showOnboarding" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" @click.self="showOnboarding=false">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-6 max-w-sm mx-4 text-center">
      <div class="text-5xl mb-3">🎓</div>
      <h2 class="text-xl font-bold mb-2 dark:text-white">雪峰AI · 高考志愿填报</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">张雪峰老师风格的AI助手，帮你分析志愿</p>
      <div class="text-left text-sm space-y-2 mb-4">
        <div class="flex items-start gap-2"><span class="text-blue-600 font-bold">1.</span>顶部设置省份+分数+选科，AI自动记住</div>
        <div class="flex items-start gap-2"><span class="text-blue-600 font-bold">2.</span>直接对话，想学什么专业？想去哪个城市？</div>
        <div class="flex items-start gap-2"><span class="text-blue-600 font-bold">3.</span>AI给出冲/稳/保三档推荐，点击校名看详情</div>
      </div>
      <button @click="showOnboarding=false;saveOnboarded()" class="w-full py-3 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700">开始使用</button>
    </div>
  </div>

  <!-- 分数线弹窗 -->
  <div v-if="showCutoffs" class="fixed inset-0 z-50 flex items-center justify-center p-4" @click.self="showCutoffs=false">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden z-10">
      <div class="flex items-center justify-between p-4 border-b dark:border-gray-700"><h3 class="text-lg font-bold dark:text-white">📊 2026年各省分数线</h3><button @click="showCutoffs=false" class="p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded">&times;</button></div>
      <div class="p-4 overflow-y-auto max-h-[60vh]">
        <p class="text-xs text-gray-400 mb-3">来源：教育部阳光高考平台 · 每日凌晨3点自动更新</p>
        <div class="mb-3 flex flex-wrap gap-2"><button v-for="p in cutoffProvinces" :key="p" @click="cutoffFilter=(cutoffFilter===p?'':p)" :class="['px-3 py-1 text-xs rounded-full border',cutoffFilter===p?'bg-blue-600 text-white border-blue-600':'border-gray-200 dark:border-gray-600 dark:text-gray-300']">{{p}}</button></div>
        <div class="overflow-x-auto"><table class="w-full text-sm"><thead><tr class="bg-gray-50 dark:bg-gray-900"><th class="p-2 text-left">省份</th><th class="p-2 text-center">类别</th><th class="p-2 text-center">特控线</th><th class="p-2 text-center">本科线</th><th class="p-2 text-center">专科线</th></tr></thead>
        <tbody><tr v-for="row in filteredCutoffs" :key="row.province+row.type" class="border-t dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700"><td class="p-2 font-medium dark:text-white">{{row.province}}</td><td class="p-2 text-center dark:text-gray-300">{{row.type}}</td><td class="p-2 text-center font-semibold" :class="row.special?'text-blue-600 dark:text-blue-400':'text-gray-400'">{{row.special||'-'}}</td><td class="p-2 text-center font-semibold" :class="row.ug?'text-blue-600 dark:text-blue-400':'text-gray-400'">{{row.ug||'-'}}</td><td class="p-2 text-center text-gray-500 dark:text-gray-400">{{row.college||'-'}}</td></tr></tbody></table></div>
        <div v-if="cutoffPending.length" class="mt-4 p-3 bg-yellow-50 dark:bg-yellow-900/30 rounded-lg text-sm text-yellow-700 dark:text-yellow-400">⏳ 以下省份待更新：{{cutoffPending.join('、')}}（每天凌晨自动查）</div>
      </div>
    </div>
  </div>

  <!-- 专业词典弹窗 -->
  <div v-if="showMajors" class="fixed inset-0 z-50 flex items-center justify-center p-4" @click.self="showMajors=false">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-hidden z-10">
      <div class="flex items-center justify-between p-4 border-b dark:border-gray-700"><h3 class="text-lg font-bold dark:text-white">📖 专业速查词典</h3><button @click="showMajors=false" class="p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded">&times;</button></div>
      <div class="p-4">
        <input v-model="majorSearch" placeholder="搜索专业..." class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 dark:text-white mb-3">
        <div class="flex flex-wrap gap-1 mb-3"><button v-for="c in majorCategories" :key="c" @click="majorSearch=c" class="px-2 py-0.5 text-xs rounded border border-gray-200 dark:border-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">{{c}}</button></div>
        <div class="overflow-y-auto max-h-[50vh] space-y-2">
          <div v-for="m in filteredMajors" :key="m.name" class="p-3 border border-gray-100 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700">
            <div class="flex items-center justify-between"><span class="font-medium dark:text-white">{{m.name}}</span><span class="text-xs text-gray-400">{{m.category}} · {{m.years}}年</span></div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{m.brief}}</p>
            <div class="flex gap-3 mt-1 text-xs text-gray-400"><span>💼{{m.jobs}}</span><span>💰{{m.avgSalary}}/月</span><span>📈{{m.prospect}}</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 院校详情弹窗 -->
  <div v-if="showUniDetail" class="fixed inset-0 z-50 flex items-center justify-center p-4" @click.self="showUniDetail=null">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-md w-full overflow-hidden z-10">
      <div class="p-4"><button @click="showUniDetail=null" class="float-right p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded">&times;</button>
        <h3 class="text-lg font-bold dark:text-white">{{showUniDetail.name}}</h3>
        <div class="flex gap-1 mt-1"><span v-for="t in showUniDetail.tags" :key="t" class="px-2 py-0.5 text-xs bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded">{{t}}</span></div>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">📍{{showUniDetail.city}} · {{showUniDetail.type}}</p>
        <div class="mt-3"><h4 class="text-sm font-semibold dark:text-white">热门专业</h4>
          <div v-for="m in showUniDetail.majors" :key="m.name" class="flex justify-between text-sm py-1 border-b dark:border-gray-700 last:border-0"><span class="dark:text-gray-300">{{m.name}} <span class="text-xs text-gray-400">{{m.rating}}</span></span><span class="text-xs text-gray-400">💰{{m.avgSalary}}/月</span></div>
        </div>
        <div class="mt-3" v-if="showUniDetail.admission"><h4 class="text-sm font-semibold dark:text-white">近年录取分</h4><div v-for="(year, y) in showUniDetail.admission" :key="y"><span class="text-xs text-gray-400">{{y}}年: </span><span v-for="(s, p) in year" :key="p" class="text-xs text-gray-600 dark:text-gray-400 ml-1">{{p}}:{{s}}分</span></div></div>
      </div>
    </div>
  </div>

  <!-- 主体 -->
  <div class="flex pt-14 h-screen">
    <!-- 侧边栏 -->
    <aside class="hidden md:flex flex-col w-56 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 overflow-y-auto flex-shrink-0">
      <div class="p-3 border-b dark:border-gray-700"><h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">历史对话</h2></div>
      <div v-if="sessions.length===0" class="p-4 text-xs text-gray-400 text-center">暂无记录</div>
      <button v-for="s in sessions" :key="s.id" @click="loadSession(s.id)" :class="['w-full text-left px-3 py-2.5 text-xs border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 truncate',s.id===currentSessionId?'bg-blue-50 dark:bg-blue-900/30 border-l-2 border-l-blue-500':'']">
        <div class="truncate font-medium dark:text-gray-200">{{s.title||'新对话'}}</div><div class="text-gray-400 mt-0.5">{{fmtTime(s.updatedAt||s.createdAt)}}</div>
      </button>
    </aside>

    <!-- 移动侧边栏 -->
    <div v-if="showSidebar" class="fixed inset-0 z-40 md:hidden" @click="showSidebar=false">
      <div class="absolute inset-0 bg-black/40"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-64 bg-white dark:bg-gray-800 shadow-xl overflow-y-auto z-50" @click.stop>
        <div class="flex items-center justify-between p-3 border-b dark:border-gray-700"><h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400">历史对话</h2><button @click="showSidebar=false" class="p-1">&times;</button></div>
        <button v-for="s in sessions" :key="s.id" @click="loadSession(s.id);showSidebar=false" :class="['w-full text-left px-4 py-3 text-sm border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700',s.id===currentSessionId?'bg-blue-50 dark:bg-blue-900/30':''"><div class="truncate font-medium dark:text-gray-200">{{s.title||'新对话'}}</div><div class="text-xs text-gray-400 mt-0.5">{{fmtTime(s.updatedAt||s.createdAt)}}</div></button>
      </aside>
    </div>

    <!-- 对话区 -->
    <main class="flex-1 flex flex-col min-w-0 bg-gray-50 dark:bg-gray-900">
      <div v-if="!currentSessionId&&messages.length===0" class="flex-1 flex items-center justify-center p-4">
        <div class="text-center max-w-md">
          <div class="text-5xl mb-4">🎓</div>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-2">雪峰AI · 高考志愿填报</h2>
          <p class="text-gray-500 dark:text-gray-400 mb-2">告诉我你的<strong>省份、分数、选科和意向</strong></p>
          <p class="text-xs text-gray-400 mb-4">已加载{{cutoffCount}}条分数线 + {{rankCount}}条位次数据</p>
          <div class="flex flex-wrap gap-2 justify-center">
            <button v-for="eg in examples" :key="eg" @click="quickStart(eg)" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-sm text-gray-600 dark:text-gray-300 hover:border-blue-400 shadow-sm">{{eg}}</button>
          </div>
        </div>
      </div>

      <div ref="msgContainer" class="flex-1 overflow-y-auto p-3 md:p-6 space-y-4">
        <div v-for="(msg,idx) in messages" :key="msg._lid||idx" class="msg-enter">
          <div v-if="msg.role==='user'" class="flex justify-end">
            <div class="max-w-[85%] md:max-w-[70%] bg-blue-600 text-white rounded-2xl rounded-br-md px-4 py-2.5 shadow-sm"><div class="whitespace-pre-wrap text-sm">{{msg.content}}</div></div>
          </div>
          <div v-else class="flex justify-start">
            <div class="max-w-[85%] md:max-w-[75%] bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl rounded-bl-md px-4 py-3 shadow-sm">
              <div class="flex items-center mb-1.5 gap-2">
                <span class="text-sm font-semibold text-gray-600 dark:text-gray-300">🤖 张雪峰风</span>
                <span v-if="msg.streaming" class="text-xs text-blue-500 animate-pulse">生成中…</span>
                <span v-if="msg.model&&!msg.streaming" class="text-xs text-gray-400">{{msg.model}} {{msg.latency}}ms</span>
              </div>
              <div v-if="msg.streaming&&msg.thinking" class="text-xs text-gray-400 italic mb-2 bg-gray-50 dark:bg-gray-700 rounded-lg p-2 thinking-pulse">💭 {{msg.thinking}}</div>
              <div class="msg-content text-sm text-gray-800 dark:text-gray-200 leading-relaxed" v-html="renderMd(msg.content)" @click="handleMsgClick"></div>
              <div v-if="!msg.streaming" class="flex items-center justify-between mt-2 pt-1.5 border-t border-gray-100 dark:border-gray-700">
                <div class="flex gap-1">
                  <button @click="sendFeedback(msg,'up')" :class="['text-xs px-1.5 py-0.5 rounded',msg.feedback==='up'?'bg-green-100 dark:bg-green-900 text-green-700':'text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700']">👍</button>
                  <button @click="sendFeedback(msg,'down')" :class="['text-xs px-1.5 py-0.5 rounded',msg.feedback==='down'?'bg-red-100 dark:bg-red-900 text-red-700':'text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700']">👎</button>
                </div>
                <button @click="copyText(msg.content)" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 px-2 py-0.5 rounded hover:bg-gray-100 dark:hover:bg-gray-700">📋复制</button>
              </div>
            </div>
          </div>
        </div>
        <div v-if="error&&!loading" class="flex justify-center"><div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg text-sm max-w-md text-center">{{error}}<button @click="retryLast" class="ml-2 underline font-medium">重试</button></div></div>
      </div>

      <div class="border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-3 md:px-6">
        <div class="max-w-3xl mx-auto flex items-end gap-2">
          <textarea v-model="inputText" @keydown.enter.exact.prevent="sendMessage" @keydown.enter.shift.exact="inputText+='\n'" :disabled="loading" placeholder="聊聊你的想法…" rows="1" class="flex-1 resize-none border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-2.5 text-sm bg-white dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-400 disabled:opacity-50 max-h-32" ref="inputEl" @input="autoResize"></textarea>
          <button @click="sendMessage" :disabled="!inputText.trim()||loading" class="px-4 py-2.5 bg-blue-600 text-white rounded-xl hover:bg-blue-700 disabled:opacity-40 transition flex-shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg></button>
        </div>
      </div>
    </main>
  </div>
</div>

<script>
const { createApp, ref, nextTick, computed, onMounted, watch } = Vue;
createApp({
  setup(){
    const API='/api/gaokao';const LS_KEY='gaokao_2026_data';const LS_PROFILE='gaokao_profile';const LS_DARK='gaokao_dark';const LS_ONBOARD='gaokao_onboarded';
    const currentSessionId=ref(null);const sessions=ref([]);const messages=ref([]);const inputText=ref('');const loading=ref(false);const error=ref('');const showSidebar=ref(false);const showCutoffs=ref(false);const showMajors=ref(false);const showScoreLinks=ref(false);const showOnboarding=ref(false);const showUniDetail=ref(null);
    const darkMode=ref(true);const cutoffFilter=ref('');const majorSearch=ref('');
    const cutoffData=ref({available:[],pendingProvinces:[],totalProvinces:0});const scoreLinks=ref({data:[],provinces:[]});const majorData=ref([]);const rankInfo=ref(null);
    const profile=ref({province:'',score:'',type:''});
    const msgContainer=ref(null);const inputEl=ref(null);let lastUserMsg='';
    const examples=['广东 物理类 620分 想学计算机','四川 理科 580分 想学医','江苏 历史类 600分 想学法学'];
    const allProvinces=['广东','江苏','河北','重庆','福建','天津','北京','辽宁','四川','山东','河南','湖南','湖北','浙江','安徽','上海','江西','山西','陕西','吉林','黑龙江','云南','贵州','广西','海南','甘肃','宁夏','青海','西藏','新疆','内蒙古'];

    // ── 深色模式 ──
    function loadDark(){try{const v=localStorage.getItem(LS_DARK);darkMode.value=v===null?true:v==='true';}catch(e){console.warn('loadDark:',e);}}
    function saveDark(){try{localStorage.setItem(LS_DARK,darkMode.value);}catch(e){console.warn('saveDark:',e);}}
    watch(darkMode,v=>{document.documentElement.className=v?'dark':'';saveDark();},{immediate:true});

    // ── localStorage ──
    function loadLocalData(){try{const r=localStorage.getItem(LS_KEY);if(r){const d=JSON.parse(r);sessions.value=d.sessions||[];currentSessionId.value=d.currentSessionId||null;if(currentSessionId.value)loadSessionMsgs(currentSessionId.value);}}catch(e){console.warn('loadLocalData:',e);}}
    function saveLocalData(){try{const am={};try{const r=localStorage.getItem(LS_KEY);if(r)Object.assign(am,JSON.parse(r).messages||{});}catch(e){console.warn('saveLocalData read:',e);}am[currentSessionId.value]=messages.value.slice(-50);const trimmedSessions=sessions.value.slice(0,30);const validIds=new Set(trimmedSessions.map(s=>s.id));for(const k of Object.keys(am)){if(!validIds.has(k))delete am[k];}try{localStorage.setItem(LS_KEY,JSON.stringify({sessions:trimmedSessions,currentSessionId:currentSessionId.value,messages:am}));}catch(e){console.warn('saveLocalData write:',e);}}catch(e){console.warn('saveLocalData:',e);}}
    function loadSessionMsgs(sid){try{const r=localStorage.getItem(LS_KEY);if(r){const am=JSON.parse(r).messages||{};messages.value=am[sid]||[];}}catch(e){console.warn('loadSessionMsgs:',e);}}
    function loadProfile(){try{const r=localStorage.getItem(LS_PROFILE);if(r)profile.value=JSON.parse(r);}catch(e){console.warn('loadProfile:',e);}}
    function saveProfile(){try{localStorage.setItem(LS_PROFILE,JSON.stringify(profile.value));}catch(e){console.warn('saveProfile:',e);}if(profile.value.province&&profile.value.score)setTimeout(()=>fetchRank(),0);}
    function loadOnboarded(){try{showOnboarding.value=!localStorage.getItem(LS_ONBOARD);}catch(e){console.warn('loadOnboarded:',e);}}
    function saveOnboarded(){try{localStorage.setItem(LS_ONBOARD,'1');}catch(e){console.warn('saveOnboarded:',e);}}

    // ── API ──
    async function api(path,body,timeoutMs=15000){const controller=new AbortController();const timer=setTimeout(()=>controller.abort(),timeoutMs);try{const r=await fetch(API+path,{...(body?{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}:{}),signal:controller.signal});if(!r.ok)throw new Error(`HTTP ${r.status}: ${r.statusText}`);return await r.json();}finally{clearTimeout(timer);}}
    async function fetchCutoffs(){try{const d=await api('/cutoffs');if(d.code===0)cutoffData.value=d.data;}catch(e){console.warn('fetchCutoffs:',e);}}
    async function fetchLinks(){try{const d=await api('/score-links');if(d.code===0)scoreLinks.value=d;}catch(e){console.warn('fetchLinks:',e);}}
    async function fetchMajors(){try{const d=await api('/majors');if(d.code===0)majorData.value=d.data;}catch(e){console.warn('fetchMajors:',e);}}
    async function fetchRank(){const{province,type,score}=profile.value;if(!province||!type||!score)return;try{const d=await api(`/rank?province=${province}&type=${type}&score=${score}`);if(d.code===0&&d.data)rankInfo.value=d.data;}catch(e){console.warn('fetchRank:',e);}}
    async function fetchUni(name){try{const d=await api(`/universities?name=${encodeURIComponent(name)}`);if(d.code===0&&d.data.length>0){showUniDetail.value=d.data[0];}}catch(e){console.warn('fetchUni:',e);}}

    // ── 计算属性 ──
    const cutoffCount=computed(()=>cutoffData.value.available?.length||0);
    const rankCount=computed(()=>rankInfo.value?1:0);
    const cutoffProvinces=computed(()=>[...new Set((cutoffData.value.available||[]).map(s=>s.province))].sort());
    const cutoffPending=computed(()=>cutoffData.value.pendingProvinces||[]);
    const filteredCutoffs=computed(()=>{const a=cutoffData.value.available||[];const f=cutoffFilter.value?a.filter(s=>s.province===cutoffFilter.value):a;const by={};for(const s of f){const k=s.province+'|'+s.type;if(!by[k])by[k]={province:s.province,type:s.type,special:null,ug:null,college:null};if(s.batch==='特控线')by[k].special=s.score;else if(s.batch==='本科线'||s.batch==='一段线')by[k].ug=s.score;else if(s.batch==='专科线'||s.batch==='二段线')by[k].college=s.score;}return Object.values(by).sort((a,b)=>a.province.localeCompare(b.province,'zh')||a.type.localeCompare(b.type,'zh'));});
    const scoreProvinces=computed(()=>scoreLinks.value.provinces||[]);
    const majorCategories=computed(()=>majorData.value.categories||[]);
    const filteredMajors=computed(()=>{let d=majorData.value.data||majorData.value;if(majorSearch.value)d=d.filter(m=>m.name.includes(majorSearch.value)||m.category.includes(majorSearch.value));return d.slice(0,20);});

    // ── SSE 聊天 ──
    async function sendMessage(){
      const text=inputText.value.trim();if(!text||loading.value)return;error.value='';inputText.value='';lastUserMsg=text;loading.value=true;
      if(!currentSessionId.value){const sid=crypto.randomUUID?crypto.randomUUID():'s_'+Date.now();currentSessionId.value=sid;sessions.value.unshift({id:sid,title:text.replace(/\n/g,' ').slice(0,20),updatedAt:new Date().toISOString()});}
      saveLocalData();
      const uLid=Date.now();messages.value.push({_lid:uLid,role:'user',content:text});await nextTick(()=>scrollBottom());
      const aLid=Date.now()+1;messages.value.push({_lid:aLid,role:'assistant',content:'',streaming:true,thinking:'正在分析…'});await nextTick(()=>scrollBottom());
      const controller=new AbortController();const chatTimer=setTimeout(()=>controller.abort(),120000);try{
        const hist=messages.value.filter(m=>!m._lid||m._lid<aLid).slice(-21,-1).map(m=>({role:m.role,content:m.content}));
        if(profile.value.province&&profile.value.score){
          hist.unshift({role:'system',content:`用户已设置：${profile.value.province} ${profile.value.type} ${profile.value.score}分`+(rankInfo.value?`（位次约${rankInfo.value.rank}名）`:'')});
        }
        hist.push({role:'user',content:text});
        const resp=await fetch(API+'/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sessionId:currentSessionId.value,message:text,history:hist}),signal:controller.signal});if(!resp.ok)throw new Error(`HTTP ${resp.status}: ${resp.statusText}`);
        const reader=resp.body.getReader();const dec=new TextDecoder();let buf='';let ai=messages.value.find(m=>m._lid===aLid);let fc=true;
        while(true){const{done,value}=await reader.read();if(done)break;buf+=dec.decode(value,{stream:true});const lines=buf.split('\n');buf=lines.pop()||'';for(const l of lines){if(!l.startsWith('data: '))continue;try{const d=JSON.parse(l.slice(6));ai=messages.value.find(m=>m._lid===aLid);if(!ai)continue;if(d.type==='thinking')ai.thinking=d.message;else if(d.type==='chunk'){if(fc){ai.thinking='';fc=false;}ai.content+=d.content;}else if(d.type==='done'){ai.streaming=false;ai.model=d.model;ai.latency=d.latency;}else if(d.type==='error'){ai.streaming=false;ai.content+='\n\n⚠️ '+d.error;error.value=d.error;}await nextTick(()=>scrollBottom());}catch(e){console.warn('SSE parse error:',e,l.slice(0,100));}}}
        ai=messages.value.find(m=>m._lid===aLid);if(ai)ai.streaming=false;
      }catch(e){error.value='连接失败: '+e.message;const ai=messages.value.find(m=>m._lid===aLid);if(ai){ai.streaming=false;ai.content+='\n\n⚠️ 连接中断';}}
      finally{clearTimeout(chatTimer);loading.value=false;const si=sessions.value.find(x=>x.id===currentSessionId.value);if(si)si.updatedAt=new Date().toISOString();saveLocalData();await nextTick(()=>scrollBottom());}
    }
    async function retryLast(){if(!lastUserMsg)return;inputText.value=lastUserMsg;await sendMessage();}
    async function newChat(){currentSessionId.value=null;messages.value=[];error.value='';await nextTick(()=>scrollBottom());}
    async function loadSession(sid){currentSessionId.value=sid;error.value='';loadSessionMsgs(sid);await nextTick(()=>scrollBottom());}
    function quickStart(t){inputText.value=t;nextTick(()=>{inputEl.value?.focus();autoResize();});}
    function gotoScore(p){const l=(scoreLinks.value.data||[]).filter(x=>x.province===p);if(l.length>0){showScoreLinks.value=false;window.open(l[0].url,'_blank','noopener');}}
    async function sendFeedback(msg,rating){msg.feedback=rating;try{await api('/feedback',{rating,message:msg.content.slice(0,100)});}catch(e){console.warn('sendFeedback:',e);}}
    async function exportForm(){
      const lines=[];lines.push('高考志愿填报参考表');lines.push('生成时间：'+new Date().toLocaleString());if(profile.value.province)lines.push(`省份：${profile.value.province} ${profile.value.type||''} ${profile.value.score?profile.value.score+'分':''}`+(rankInfo.value?` 位次：${rankInfo.value.rank}`:''));lines.push('---');
      for(const m of messages.value){if(m.role==='assistant')lines.push(m.content);}
      const blob=new Blob([lines.join('\n\n')],{type:'text/plain;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='志愿填报参考_'+new Date().toISOString().slice(0,10)+'.txt';a.click();
    }
    function handleMsgClick(e){const t=e.target;if(t.classList.contains('school-link')){fetchUni(t.textContent);}}

    // ── UI ──
    function scrollBottom(){nextTick(()=>{if(msgContainer.value)msgContainer.value.scrollTop=msgContainer.value.scrollHeight;});}
    function autoResize(){const el=inputEl.value;if(!el)return;el.style.height='auto';el.style.height=Math.min(el.scrollHeight,128)+'px';}
    function fmtTime(ts){if(!ts)return'';const d=new Date(ts),diff=Date.now()-d;if(diff<6e4)return'刚刚';if(diff<36e5)return Math.floor(diff/6e4)+'分钟前';if(diff<864e5)return Math.floor(diff/36e5)+'小时前';return d.toLocaleDateString('zh-CN',{month:'short',day:'numeric'});}
    function renderMd(t){if(!t)return'';try{marked.setOptions({breaks:true,gfm:true});let h=marked.parse(t);h=h.replace(/<script[\s\S]*?<\/script>/gi,'');h=h.replace(/<iframe[\s\S]*?<\/iframe>/gi,'');h=h.replace(/\bon\w+\s*=\s*"[^"]*"/gi,'');h=h.replace(/\bon\w+\s*=\s*'[^']*'/gi,'');h=h.replace(/\bon\w+\s*=\s*[^"'\s][^>\s]*/gi,'');h=h.replace(/javascript\s*:/gi,'');h=h.replace(/<svg[\s>][\s\S]*?<\/svg>/gi,'');h=h.replace(/<math[\s>][\s\S]*?<\/math>/gi,'');h=h.replace(/(\S{2,6}(大学|学院))/g,'<span class="school-link" title="点击查看院校详情">$1</span>');return h;}catch(e){return t.replace(/</g,'&lt;');}}
    async function copyText(t){try{await navigator.clipboard.writeText(t);}catch(e){console.warn('copyText:',e);const ta=document.createElement('textarea');ta.value=t;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);}}

    onMounted(async()=>{
      loadDark();loadLocalData();loadProfile();loadOnboarded();
      await Promise.all([fetchCutoffs(),fetchLinks(),fetchMajors()]);
      if(profile.value.province&&profile.value.score)await fetchRank();
      if(sessions.value.length>0&&currentSessionId.value)await loadSession(currentSessionId.value);
      document.addEventListener('keydown',(e)=>{if(e.key==='Escape'){showSidebar.value=false;showCutoffs.value=false;showMajors.value=false;showScoreLinks.value=false;}});
    });

    return{currentSessionId,sessions,messages,inputText,loading,error,showSidebar,showCutoffs,showMajors,showScoreLinks,showOnboarding,showUniDetail,darkMode,cutoffFilter,majorSearch,cutoffData,cutoffCount,rankCount,cutoffProvinces,cutoffPending,filteredCutoffs,scoreLinks,scoreProvinces,majorData,majorCategories,filteredMajors,rankInfo,profile,allProvinces,msgContainer,inputEl,examples,sendMessage,retryLast,newChat,loadSession,quickStart,gotoScore,sendFeedback,exportForm,handleMsgClick,scrollBottom,autoResize,fmtTime,renderMd,copyText,fetchRank,saveDark,saveProfile,saveOnboarded};
  }
}).mount('#app');
</script>
</body>
</html>
